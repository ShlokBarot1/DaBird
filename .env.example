# Storefront API (required)
VITE_SHOPIFY_STORE_DOMAIN=your-store.myshopify.com
VITE_SHOPIFY_STOREFRONT_TOKEN=

# Shop tabs: collection HANDLES (Admin → Products → Collections → handle in URL)
# When set, that tab shows exactly those products (beanies can appear under Hats and Bobbles if you add them to both collections).
VITE_SHOPIFY_COLLECTION_HATS=hats
VITE_SHOPIFY_COLLECTION_SHIRTS=shirts
VITE_SHOPIFY_COLLECTION_BOBBLES=bobbles

# Optional: featured carousel collection handle
VITE_SHOPIFY_FEATURED_COLLECTION=

# Optional: override account/login URL (custom domain or new customer accounts)
# VITE_SHOPIFY_ACCOUNT_URL=https://your-domain.com/account/login
